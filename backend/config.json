{
  "app_name": "Local Meeting AI",
  "offline_mode": true,
  "paths": {
    "ffmpeg": "ffmpeg.exe",
    "stt_model": "./models/stt/cohere-transcribe-03-2026",
    "diarization_model": "./models/diarization/speaker-diarization-community-1",
    "segmentation_model": "",
    "llm_model": "./models/llm/gemma.gguf",
    "output_dir": "./outputs",
    "temp_dir": "./temp",
    "log_dir": "./logs"
  },
  "stt": {
    "language": "ko",
    "default_model": "cohere-transcribe-03-2026",
    "fallback_model": "faster-whisper-large-v3",
    "device": "auto",
    "chunk_seconds": 30
  },
  "processing": {
    "long_audio_chunk_seconds": 30,
    "enable_long_audio_chunking": true
  },
  "diarization": {
    "enabled": true,
    "min_speakers": null,
    "max_speakers": null
  },
  "summary": {
    "enabled": true,
    "mode": "meeting_minutes",
    "provider": "ollama",
    "model": "gemma4:e2b"
  },
  "export_templates": {
    "use_custom_template": false,
    "hwpx_template_path": "./templates/default_meeting.hwpx",
    "docx_template_path": "./templates/default_meeting.docx",
    "comment": "FUTURE: HWPX나 DOCX 템플릿 기반 보고서 생성 기능을 위한 설정입니다."
  },
  "privacy": {
    "send_data_to_server": false,
    "auto_delete_temp_audio": true,
    "save_logs": true,
    "save_original_audio_copy": false
  }
}
