{
  "app_name": "Local Meeting AI",
  "offline_mode": true,
  "paths": {
    "ffmpeg": "ffmpeg.exe",
    "stt_model": "../models/faster-whisper-large-v3",
    "diarization_model": "../models",
    "segmentation_model": "",
    "llm_model": "./models/llm/gemma.gguf",
    "output_dir": "./outputs",
    "temp_dir": "./temp",
    "log_dir": "./logs"
  },
  "stt": {
    "language": "ko",
    "selected_model": "faster-whisper-large-v3",
    "default_model": "faster-whisper-large-v3",
    "fallback_model": "",
    "device": "cpu",
    "chunk_seconds": 30
  },
  "processing": {
    "long_audio_chunk_seconds": 30,
    "enable_long_audio_chunking": true
  },
  "preprocessing": {
    "enabled": true,
    "noise_gate": false,
    "normalize_audio": true,
    "normalization_mode": "auto",
    "trim_silence": false,
    "denoise": false
  },
  "diarization": {
    "enabled": true,
    "generate_during_analysis": false,
    "auto_skip_long_audio": true,
    "max_duration_seconds": 9000,
    "max_waveform_mb": 512,
    "min_speakers": null,
    "max_speakers": null
  },
  "summary": {
    "enabled": true,
    "generate_during_analysis": false,
    "mode": "meeting_minutes",
    "provider": "ollama",
    "model": "gemma4:e2b",
    "model_options": [
      {
        "model": "gemma4:e2b",
        "label": "권장 2B",
        "description": "용량과 속도를 우선할 때 사용합니다.",
        "url": "https://ollama.com/library/gemma4%3Ae2b",
        "command": "ollama run gemma4:e2b"
      },
      {
        "model": "gemma4:e4b",
        "label": "선택 4B",
        "description": "PC 여유가 있으면 더 큰 모델을 사용할 수 있습니다.",
        "url": "https://ollama.com/library/gemma4%3Ae4b",
        "command": "ollama run gemma4:e4b"
      },
      {
        "label": "모델 목록",
        "description": "Ollama에서 Gemma 4 모델을 비교합니다.",
        "url": "https://ollama.com/library/gemma4"
      }
    ]
  },
  "export_templates": {
    "use_custom_template": false,
    "hwpx_template_path": "./templates/default_meeting.hwpx",
    "docx_template_path": "./templates/default_meeting.docx",
    "comment": "FUTURE: HWPX나 DOCX 템플릿 기반 보고서 생성 기능을 위한 설정입니다."
  },
  "privacy": {
    "send_data_to_server": false,
    "auto_delete_temp_audio": true,
    "save_logs": true,
    "save_original_audio_copy": false,
    "preserve_extracted_audio": true,
    "auto_save_hwpx_copy": false,
    "auto_save_audio_copy": false
  }
}
