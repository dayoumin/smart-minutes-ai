{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LMO 스마트 회의시스템",
  "version": "0.1.0",
  "identifier": "com.nifs.smart-minutes-ai",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:desktop",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LMO 스마트 회의시스템",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/meeting-backend"
    ],
    "resources": {
      "resources/backend": "backend"
    }
  }
}
